      "page": "/api/auth/[...path]",
      "regex": "^/api/auth/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPpath": "nxtPpath"
      },
      "namedRegex": "^/api/auth/(?<nxtPpath>.+?)(?:/)?$"
    },
    {
